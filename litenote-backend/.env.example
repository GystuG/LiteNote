# 服务端口
PORT=3006

# JWT 认证密钥（必须修改）
JWT_SECRET=change-me-your-jwt-secret

# PostgreSQL 数据库连接（必须修改）
DATABASE_URL="postgresql://user:password@localhost:5432/litenote?sslmode=require"

# API 外部访问地址（可选，用于生成下载链接等，留空则自动从请求中获取）
API_BASE_URL=

# ASR 语音识别配置（可选，用于语音记账功能，兼容 OpenAI Whisper 协议）
ASR_API_URL=
ASR_API_KEY=
ASR_MODEL=
