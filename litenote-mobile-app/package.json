{
  "name": "LiteNote",
  "version": "0.0.28",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "android:dev": "cross-env ENVFILE=.env.development react-native run-android",
    "android:prod": "cross-env ENVFILE=.env.production react-native run-android",
    "ios": "react-native run-ios",
    "ios:dev": "cross-env ENVFILE=.env.development react-native run-ios",
    "ios:prod": "cross-env ENVFILE=.env.production react-native run-ios",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "start": "react-native start",
    "start:reset": "react-native start --reset-cache",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "build:dev": "cd android && gradlew assembleDebug",
    "build:prod": "cd android && gradlew assembleRelease",
    "clean": "react-native clean-project-auto",
    "postinstall": "npx react-native-asset",
    "release": "node scripts/release.js patch",
    "release:patch": "node scripts/release.js patch",
    "release:minor": "node scripts/release.js minor",
    "release:major": "node scripts/release.js major",
    "hot-update": "node scripts/release-bundle.js",
    "hot-update:dev": "node scripts/release-bundle.js --dev",
    "hot-update:force": "node scripts/release-bundle.js --force",
    "hot-update:dev:force": "node scripts/release-bundle.js --dev --force"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native/gradle-plugin": "^0.81.1",
    "@react-native/new-app-screen": "0.81.4",
    "@react-navigation/bottom-tabs": "^7.4.7",
    "@react-navigation/native": "^7.1.17",
    "@react-navigation/native-stack": "^7.3.26",
    "@sentry/react-native": "^7.10.0",
    "@tanstack/react-query": "^5.90.19",
    "axios": "^1.12.2",
    "litenote": "file:..",
    "lucide-react-native": "^0.563.0",
    "mobx": "^6.15.0",
    "mobx-react-lite": "^4.1.1",
    "react": "19.1.0",
    "react-native": "0.81.4",
    "react-native-audio-recorder-player": "^4.5.0",
    "react-native-blob-util": "^0.24.6",
    "react-native-config": "^1.5.9",
    "react-native-dotenv": "^3.4.11",
    "react-native-fs": "^2.20.0",
    "react-native-gifted-charts": "^1.4.76",
    "react-native-image-picker": "^8.2.1",
    "react-native-image-viewing": "^0.2.2",
    "react-native-linear-gradient": "^2.8.3",
    "react-native-nitro-modules": "^0.33.9",
    "react-native-paper": "^5.14.5",
    "react-native-safe-area-context": "^5.6.1",
    "react-native-screens": "^4.16.0",
    "react-native-skeleton-placeholder": "^5.2.4",
    "react-native-sse": "^1.2.1",
    "react-native-svg": "^15.15.1",
    "react-native-vector-icons": "^10.3.0",
    "react-native-zip-archive": "^7.0.2"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@react-native-community/cli": "20.0.0",
    "@react-native-community/cli-platform-android": "20.0.0",
    "@react-native-community/cli-platform-ios": "20.0.0",
    "@react-native/babel-preset": "0.81.4",
    "@react-native/eslint-config": "0.81.4",
    "@react-native/metro-config": "0.81.4",
    "@react-native/typescript-config": "0.81.4",
    "@types/jest": "^29.5.13",
    "@types/react": "^19.1.0",
    "@types/react-test-renderer": "^19.1.0",
    "adm-zip": "^0.5.16",
    "apisauce": "^3.2.1",
    "cross-env": "^10.1.0",
    "eslint": "^8.19.0",
    "form-data": "^4.0.0",
    "jest": "^29.6.3",
    "prettier": "2.8.8",
    "react-test-renderer": "19.1.0",
    "reactotron-apisauce": "^3.0.7",
    "reactotron-react-js": "^3.3.17",
    "reactotron-react-native": "^5.1.18",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20"
  }
}
